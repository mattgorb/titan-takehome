{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"\\n## \" + (now | strftime(\"%Y-%m-%d %H:%M:%S\")) + \" (user)\\n\\n\" + .prompt + \"\\n\"' >> /Users/matt/Desktop/projects/titan/prompt-log.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/matt/Desktop/projects/titan/.claude/log-assistant.sh"
          }
        ]
      }
    ]
  }
}
